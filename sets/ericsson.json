{
  "name": "ericsson",
  "version": "0.1.0",
  "description": "Shared Ericsson coworker capabilities (OTTO + LOOP24)",
  "skills": [
    "skills/ericsson/workflow-orchestrator",
    "skills/ericsson/workflow-builder"
  ],
  "plugins": [
    "plugins/ericsson-jira",
    "plugins/ericsson-teams"
  ],
  "mcpServers": "mcp/mcp-servers.yaml",
  "mcpLocal": ["mcp/outlook-mcp"],
  "workflows": [
    "workflows/my-tickets-summary.yml",
    "workflows/inbox-digest.yml"
  ],
  "personas": [],
  "env": [
    {"key": "ERICSSON_ENV", "description": "Set to 1 on Ericsson machines to enable Ericsson capabilities", "category": "skill"},
    {"key": "JIRA_BASE_URL", "description": "Ericsson Jira base URL", "category": "skill"},
    {"key": "JIRA_PAT", "description": "Jira personal access token", "category": "skill", "password": true},
    {"key": "GLEAN_MCP_URL", "description": "Glean MCP endpoint (internal document search)", "category": "skill"},
    {"key": "GLEAN_API_TOKEN", "description": "Glean API token", "category": "skill", "password": true}
  ]
}
